# ── TextStream Environment Variables ─────────────────────────────

# Backend
# --------
# Railway injects $PORT automatically. No need to set it here.
# FFMPEG_PATH is detected via PATH on Railway (Nixpacks installs it).
# Override only if using a custom FFmpeg binary:
# FFMPEG_PATH=/path/to/ffmpeg

# Frontend (set these in Railway dashboard under the frontend service)
# ----------
# The URL of the deployed backend service (REST API + WebSocket).
# Example: https://textstream-backend.up.railway.app
VITE_API_URL=https://your-backend-service-url.railway.app
VITE_WS_URL=wss://your-backend-service-url.railway.app/ws/stream

# Convex (if used alongside TextStream features)
# -------
# VITE_CONVEX_URL=https://your-convex-project.convex.cloud
